{
  "name": "dashboard",
  "version": "1.0.0",
  "description": "Dashboard ATM con frontend moderno y API segura lista para base de datos",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "npm run build && node dist/server.js",
    "dev": "npm run build:frontend && tsx watch server.ts",
    "test": "echo \"Sin pruebas automatizadas aún\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calvin261/dashboard.git"
  },
